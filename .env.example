# =============================================================================
# Shaadi AI Planner — environment variables
# Copy to .env.local for development. Set the same keys in Vercel → Environment Variables.
# =============================================================================

# Canonical public URL (required in production for SEO / Open Graph)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Project Settings → API (Legacy anon key tab)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Groq AI — server-only (NEVER use NEXT_PUBLIC_ prefix)
GROQ_API_KEY=your-groq-api-key

# Optional — not used by v1 app routes
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
