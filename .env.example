# Public app URL for SEO metadata (production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — public anon key (RLS should gate access when Auth is enabled)
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets (NEVER prefix with NEXT_PUBLIC_)
# Used by Route Handlers, Server Actions, lib/groq.ts, lib/env.server.ts
GROQ_API_KEY=your-groq-api-key

# Optional — bypasses RLS; NOT used by this app in v1. Background jobs only.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
